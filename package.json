{
	"name": "nutrip-api",
	"version": "1.0.0",
	"engines": {
		"node": ">=14.15.4"
	},
	"description": "",
	"scripts": {
		"prebuild": "rimraf build",
		"build": "tsc",
		"postbuild": "cpy '**/*' '!**/*.ts' ../build/ --cwd=src/ --no-overwrite --parents",
		"prestart": "npm run build",
		"start": "NODE_PATH=./build node build/bootstrap",
		"start:watch": "NODE_PATH=./src ts-node-dev --respawn --transpile-only --pretty src/bootstrap",
		"debug": "NODE_PATH=./src ts-node-dev --inspect --respawn --transpile-only --pretty src/bootstrap",
		"test": "jest --watch",
		"format:staged": "pretty-quick --staged",
		"lint:staged": "lint-staged",
		"commit": "npm run lint:staged && npm run format:staged"
	},
	"husky": {
		"hooks": {
			"pre-commit": "npm run format:staged"
		}
	},
	"lint-staged": {
		"*.ts": [
			"eslint --fix --color"
		]
	},
	"author": "gustavolizze",
	"license": "ISC",
	"devDependencies": {
		"@types/jest": "^26.0.20",
		"@types/lodash": "^4.14.167",
		"@types/node": "^14.14.21",
		"@types/reflect-metadata": "^0.1.0",
		"@types/source-map-support": "^0.5.3",
		"@types/throng": "^5.0.0",
		"@typescript-eslint/eslint-plugin": "^4.13.0",
		"@typescript-eslint/parser": "^4.13.0",
		"cpy-cli": "^3.1.1",
		"eslint": "^7.17.0",
		"eslint-config-prettier": "^7.1.0",
		"eslint-plugin-node": "^11.1.0",
		"eslint-plugin-sonarjs": "^0.5.0",
		"husky": "^4.3.7",
		"jest": "^26.6.3",
		"jest-extended": "^0.11.5",
		"lint-staged": "^10.5.3",
		"prettier": "^2.2.1",
		"pretty-quick": "^3.1.0",
		"rimraf": "^3.0.2",
		"ts-jest": "^26.4.4",
		"ts-node-dev": "^1.1.1",
		"typescript": "^4.1.3"
	},
	"dependencies": {
		"lodash": "^4.17.20",
		"make-promises-safe": "^5.1.0",
		"reflect-metadata": "^0.1.13",
		"source-map-support": "^0.5.19",
		"throng": "^5.0.0"
	}
}
